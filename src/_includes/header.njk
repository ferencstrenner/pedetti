<header>
    {% set t = translations[lang] or translations['hu'] %}
    {% set nav = t.nav or {} %}
    <div class="header-content">
        <div class="site-tagline">
            <div class="tagline-text">
                <div class="tagline-title">Pedetti Apartman Balatonfüred</div>
                <div class="tagline-sub">{{ (translations[lang] or translations['hu']).tagline_sub }}</div>
            </div>
            <img src="/assets/logo.png" alt="Pedetti Apartman logo" class="header-logo" decoding="async" fetchpriority="high">
        </div>

        <h1 style="display:none">🏡 {{ site.name or 'Pedetti Apartman' }} 🌿</h1>

        <div class="header-top-bar">
            {% include "social.njk" %}
            
            {% include "lang.njk" %}
        </div>

            <!-- Mobile hamburger button -->
            <button class="hamburger" aria-controls="main-nav" aria-expanded="false" aria-label="Menü">☰</button>

            <nav id="main-nav">
                <a href="/{{ lang }}/">🏠 {% if nav.home %}{{ nav.home }}{% elif lang == 'en' %}Home{% elif lang == 'de' %}Startseite{% else %}Kezdőlap{% endif %}</a>
                <a href="/{{ lang }}/price/">💰 {% if nav.price %}{{ nav.price }}{% elif lang == 'en' %}Prices{% elif lang == 'de' %}Preise{% else %}Árak{% endif %}</a>
                <a href="/{{ lang }}/prog/">📅 {% if nav.prog %}{{ nav.prog }}{% elif lang == 'en' %}Programs{% elif lang == 'de' %}Programm{% else %}Programok{% endif %}</a>
                <a href="/{{ lang }}/contact/">📞 {% if nav.contact %}{{ nav.contact }}{% elif lang == 'en' %}Booking{% elif lang == 'de' %}Buchung{% else %}Foglalás{% endif %}</a>
                <a href="/{{ lang }}/rules/">📋 {% if nav.rules %}{{ nav.rules }}{% elif lang == 'en' %}House Rules{% elif lang == 'de' %}Hausordnung{% else %}Házirend{% endif %}</a>
                <a href="/{{ lang }}/gdpr/">🔒 {% if nav.gdpr %}{{ nav.gdpr }}{% elif lang == 'en' %}Privacy Policy{% elif lang == 'de' %}Datenschutz{% else %}Adatkezelés{% endif %}</a>
            </nav>
    </div>
</header>